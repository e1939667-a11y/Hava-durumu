## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/

# NuGet
*.nupkg
*.snupkg

# Visual Studio cache/options
.vs/

# Visual Studio Code
.vscode/

# Node modules (if using Electron)
node_modules/
package-lock.json

# Output folder
bin/
obj/
